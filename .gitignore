# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Environment
.env
*.env.local

# Language state (set by setup.sh --lang)
.claude/.current-lang

# Claude Code local settings (contains MCP server permissions, may contain API keys)
.claude/settings.local.json

# IDE
.vscode/
.idea/
*.swp
*.swo
.codex

# OS
.DS_Store
Thumbs.db

# Virtual environment
.venv/

# Raw data (large files managed separately)
raw/papers/*.pdf

# Visualization-generated artifacts (regenerated by tools/visualize.py)
wiki/.obsidian/
wiki/canvases/

# Skill checkpoints (local state for /init, /daily-arxiv, /research, etc.)
.checkpoints/
wiki/.checkpoints/

# Daily-arxiv / demo run outputs (regenerated every run; the tracked pinned
# references are examples/output/bio-*.md and examples/output/digest-sample.md)
examples/output/context.json
examples/output/decisions.json
examples/output/digest.json
examples/output/digest.md

# Local-only demo workpads (用户自用，不推送)
docs/bio-adaptation/DEMO_SUBMISSION.zh.md
docs/bio-adaptation/DEMO_WALKTHROUGH.zh.md